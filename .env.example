# ──────────────────────────────────────────────
# grc-engineered environment variables
# Copy this file to .env and fill in your values
# Never commit .env to version control
# ──────────────────────────────────────────────

# Required — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# Optional — Slack webhook for drift/triage alerts
SLACK_WEBHOOK_URL=

# Optional — Jira integration for ticket creation
JIRA_URL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# Optional — ChromaDB path (defaults to ./.chromadb)
CHROMA_DB_PATH=./.chromadb

# Optional — override default Claude model
CLAUDE_MODEL=claude-sonnet-4-5
