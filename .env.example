# ──────────────────────────────────────────────────────────────────────────────
# grc-engineered environment variables
# Copy this file to .env and fill in your values
# Never commit .env to version control
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose your backend: "anthropic" (default) or "ollama" (free, runs locally)
LLM_PROVIDER=anthropic

# ── Anthropic (required when LLM_PROVIDER=anthropic) ─────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here
# Optional: override the default model
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Ollama (required when LLM_PROVIDER=ollama) ───────────────────────────────
# Install Ollama from https://ollama.com, then run: ollama pull llama3.2
# Models with tool support: llama3.2, llama3.1, qwen2.5, mistral-nemo
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Optional: Slack alerts ───────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# ── Optional: Jira ticket creation ───────────────────────────────────────────
JIRA_SERVER=
JIRA_EMAIL=
JIRA_API_TOKEN=

# ── Storage paths (defaults shown) ───────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db
SQLITE_DB_PATH=./memory.db
KNOWLEDGE_PATH=./knowledge
OUTPUTS_PATH=./outputs
